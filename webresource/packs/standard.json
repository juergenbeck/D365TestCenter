  "description": "Standardtabellen und -felder aus Dynamics 365 Sales und Service. Keine Custom-Entities erforderlich.",
  "color": "#42a5f5",
  "testCases": [
    {
      "jbe_testcaseid": "d1d2d3d4-0001-4000-8000-100000000001",
      "jbe_testid": "STD-TC01",
      "jbe_title": "Lead-Qualifizierung: Opportunity wird erstellt",
      "jbe_category": 100000005,
      "jbe_tags": "Lead,Opportunity,Sales",
      "jbe_userstories": "PROJ-2001",
      "jbe_enabled": true,
      "jbe_definitionjson": {
        "preconditions": {
          "createAccount": true
        },
        "steps": [
          {
            "action": "CreateRecord",
            "entity": "lead",
            "alias": "lead1",
            "fields": {
              "firstname": "{GENERATED:firstname}",
              "lastname": "{GENERATED:lastname}",
              "emailaddress1": "{GENERATED:email}",
              "companyname": "Firma Alpha GmbH",
              "leadqualitycode": 1
            }
          },
          {
            "action": "UpdateRecord",
            "alias": "lead1",
            "fields": {
              "statuscode": 3
            },
            "waitForAsync": true
          }
        ],
        "assertions": [
          {
            "target": "Query",
            "entity": "opportunity",
            "filter": {
              "originatingleadid": "{lead1.id}"
            },
            "field": "name",
            "operator": "Contains",
            "value": "{lead1.lastname}"
          }
        ]
      }
    },
    {
      "jbe_testcaseid": "d1d2d3d4-0002-4000-8000-100000000002",
      "jbe_testid": "STD-TC02",
      "jbe_title": "Opportunity auf Won: Account-Umsatz aktualisiert",
      "jbe_category": 100000005,
      "jbe_tags": "Opportunity,Account,Revenue",
      "jbe_userstories": "",
      "jbe_enabled": true,
      "jbe_definitionjson": {
        "preconditions": {
          "createAccount": true,
          "createOpportunity": true
        },
        "steps": [
          {
            "action": "UpdateRecord",
            "alias": "opp1",
            "fields": {
              "statuscode": 3,
              "actualvalue": 50000,
              "actualclosedate": "{TIMESTAMP}"
            },
            "waitForAsync": true
          }
        ],
        "assertions": [
          {
            "target": "Record:account1",
            "field": "revenue",
            "operator": "GreaterThan",
            "value": "0"
          }
        ]
      }
    },
    {
      "jbe_testcaseid": "d1d2d3d4-0003-4000-8000-100000000003",
      "jbe_testid": "STD-TC03",
      "jbe_title": "Case-Eskalation: High Priority Routing",
      "jbe_category": 100000005,
      "jbe_tags": "Case,Routing,Service",
      "jbe_userstories": "PROJ-2002",
      "jbe_enabled": true,
      "jbe_definitionjson": {
        "steps": [
          {
            "action": "CreateRecord",
            "entity": "incident",
            "alias": "case1",
            "fields": {
              "title": "Dringend: {GENERATED:text}",
              "prioritycode": 1,
              "caseorigincode": 1,
              "customerid_account": "{ACCOUNT_ID}"
            },
            "waitForAsync": true,
            "stepNumber": 1
          },
          {
            "action": "Assert",
            "target": "Record:case1",
            "field": "ownerid",
            "operator": "NotEquals",
            "value": "{CURRENT_USER}",
            "onError": "continue",
            "stepNumber": 2
          }
        ]
      }
    },
    {
      "jbe_testcaseid": "d1d2d3d4-0004-4000-8000-100000000004",
      "jbe_testid": "STD-TC04",
      "jbe_title": "Contact-Adresse: Kaskade auf verknüpfte Cases",
      "jbe_category": 100000005,
      "jbe_tags": "Contact,Case,Adresse",
      "jbe_userstories": "",
      "jbe_enabled": true,
      "jbe_definitionjson": {
        "preconditions": {
          "createContact": true,
          "createCase": true
        },
        "steps": [
          {
            "action": "UpdateRecord",
            "alias": "contact1",
            "fields": {
              "address1_city": "Berlin",
              "address1_postalcode": "10115"
            },
            "waitForAsync": true
          }
        ],
        "assertions": [
          {
            "target": "Query",
            "entity": "incident",
            "filter": {
              "primarycontactid": "{contact1.id}"
            },
            "field": "customeraddress_city",
            "operator": "Equals",
            "value": "Berlin"
          }
        ]
      }
    },
    {
      "jbe_testcaseid": "d1d2d3d4-0005-4000-8000-100000000005",
      "jbe_testid": "STD-TC05",
      "jbe_title": "Task-Erinnerung: Workflow bei Fälligkeit",
      "jbe_category": 100000005,
      "jbe_tags": "Activity,Task,Workflow",
      "jbe_userstories": "",
      "jbe_enabled": true,
      "jbe_definitionjson": {
        "steps": [
          {
            "action": "CreateRecord",
            "entity": "task",
            "alias": "task1",
            "fields": {
              "subject": "Rückruf {GENERATED:lastname}",
              "scheduledend": "{TIMESTAMP_PLUS_1H}",
              "prioritycode": 2,
              "regardingobjectid_contact": "{CONTACT_ID}"
            },
            "waitForAsync": true,
            "stepNumber": 1
          },
          {
            "action": "Assert",
            "target": "Query",
            "field": "statuscode",
            "entity": "activitypointer",
            "filter": {
              "regardingobjectid": "{task1.regardingobjectid}"
            },
            "operator": "NotEquals",
            "value": "5",
            "onError": "continue",
            "stepNumber": 2
          }
        ]
      }
    },
    {
      "jbe_testcaseid": "d1d2d3d4-0006-4000-8000-100000000006",
      "jbe_testid": "STD-TC06",
      "jbe_title": "Account-Deduplizierung: Warnung bei gleicher Email",
      "jbe_category": 100000006,
      "jbe_tags": "Account,Duplikat,DQM",
      "jbe_userstories": "",
      "jbe_enabled": true,
      "jbe_definitionjson": {
        "preconditions": {
          "createAccount": true
        },
        "steps": [
          {
            "action": "CreateRecord",
            "entity": "account",
            "alias": "acc_dup",
            "fields": {
              "name": "{account1.name}",
              "emailaddress1": "{account1.emailaddress1}"
            }
          }
        ],
        "assertions": [
          {
            "target": "Query",
            "entity": "duplicaterecord",
            "filter": {
              "baserecordid": "{acc_dup.id}"
            },
            "field": "duplicaterecordid",
            "operator": "IsNotNull"
          }
        ]
      }
    },
    {
      "jbe_testcaseid": "d1d2d3d4-0007-4000-8000-100000000007",
      "jbe_testid": "STD-TC07",
      "jbe_title": "Opportunity-Pipeline: Phase-Wechsel Validierung",
      "jbe_category": 100000005,
      "jbe_tags": "Opportunity,BPF,Pipeline",
      "jbe_userstories": "PROJ-2001",
      "jbe_enabled": true,
      "jbe_definitionjson": {
        "preconditions": {
          "createOpportunity": true
        },
        "steps": [
          {
            "action": "UpdateRecord",
            "alias": "opp1",
            "fields": {
              "stepname": "Propose",
              "salesstage": 2
            },
            "waitForAsync": true
          }
        ],
        "assertions": [
          {
            "target": "Record:opp1",
            "field": "salesstage",
            "operator": "Equals",
            "value": "2"
          },
          {
            "target": "Record:opp1",
            "field": "stepname",
            "operator": "Equals",
            "value": "Propose"
          }
        ]
      }
    },
    {
      "jbe_testcaseid": "d1d2d3d4-0008-4000-8000-100000000008",
      "jbe_testid": "STD-TC08",
      "jbe_title": "Case-SLA: Timer startet bei Erstellung",
      "jbe_category": 100000005,
      "jbe_tags": "Case,SLA,Timer,Service",
      "jbe_userstories": "PROJ-2002",
      "jbe_enabled": true,
      "jbe_definitionjson": {
        "steps": [
          {
            "action": "CreateRecord",
            "entity": "incident",
            "alias": "sla_case",
            "fields": {
              "title": "SLA-Test {GENERATED:text}",
              "prioritycode": 2,
              "customerid_account": "{ACCOUNT_ID}"
            },
            "waitForAsync": true,
            "maxDurationMs": 10000,
            "stepNumber": 1
          },
          {
            "action": "Assert",
            "target": "Record:sla_case",
            "field": "slainvokedid",
            "operator": "IsNotNull",
            "onError": "continue",
            "stepNumber": 2
          }
        ]
      }
    }
  ],
