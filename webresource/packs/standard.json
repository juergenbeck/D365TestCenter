{
  "packId": "standard",
  "name": "Standard CRM (Sales & Service)",
  "description": "Standardtabellen und -felder aus Dynamics 365 Sales und Service. Keine Custom-Entities erforderlich.",
  "color": "#42a5f5",
  "testCases": [
    {
      "itt_testcaseid": "d1d2d3d4-0001-4000-8000-100000000001",
      "itt_testid": "STD-TC01",
      "itt_title": "Lead-Qualifizierung: Opportunity wird erstellt",
      "itt_category": 100000005,
      "itt_tags": "Lead,Opportunity,Sales",
      "itt_userstories": "PROJ-2001",
      "itt_enabled": true,
      "itt_definitionjson": {
        "preconditions": { "createAccount": true },
        "steps": [
          { "action": "CreateRecord", "entity": "lead", "alias": "lead1", "fields": { "firstname": "{GENERATED:firstname}", "lastname": "{GENERATED:lastname}", "emailaddress1": "{GENERATED:email}", "companyname": "Firma Alpha GmbH", "leadqualitycode": 1 } },
          { "action": "UpdateRecord", "alias": "lead1", "fields": { "statuscode": 3 }, "waitForAsync": true }
        ],
        "assertions": [
          { "target": "Query", "entity": "opportunity", "filter": { "originatingleadid": "{lead1.id}" }, "field": "name", "operator": "Contains", "value": "{lead1.lastname}" }
        ]
      }
    },
    {
      "itt_testcaseid": "d1d2d3d4-0002-4000-8000-100000000002",
      "itt_testid": "STD-TC02",
      "itt_title": "Opportunity auf Won: Account-Umsatz aktualisiert",
      "itt_category": 100000005,
      "itt_tags": "Opportunity,Account,Revenue",
      "itt_userstories": "",
      "itt_enabled": true,
      "itt_definitionjson": {
        "preconditions": { "createAccount": true, "createOpportunity": true },
        "steps": [
          { "action": "UpdateRecord", "alias": "opp1", "fields": { "statuscode": 3, "actualvalue": 50000, "actualclosedate": "{TIMESTAMP}" }, "waitForAsync": true }
        ],
        "assertions": [
          { "target": "Record:account1", "field": "revenue", "operator": "GreaterThan", "value": "0" }
        ]
      }
    },
    {
      "itt_testcaseid": "d1d2d3d4-0003-4000-8000-100000000003",
      "itt_testid": "STD-TC03",
      "itt_title": "Case-Eskalation: High Priority Routing",
      "itt_category": 100000005,
      "itt_tags": "Case,Routing,Service",
      "itt_userstories": "PROJ-2002",
      "itt_enabled": true,
      "itt_definitionjson": {
        "steps": [
          { "action": "CreateRecord", "entity": "incident", "alias": "case1", "fields": { "title": "Dringend: {GENERATED:text}", "prioritycode": 1, "caseorigincode": 1, "customerid_account": "{ACCOUNT_ID}" }, "waitForAsync": true }
        ],
        "assertions": [
          { "target": "Record:case1", "field": "ownerid", "operator": "NotEquals", "value": "{CURRENT_USER}" }
        ]
      }
    },
    {
      "itt_testcaseid": "d1d2d3d4-0004-4000-8000-100000000004",
      "itt_testid": "STD-TC04",
      "itt_title": "Contact-Adresse: Kaskade auf verknüpfte Cases",
      "itt_category": 100000005,
      "itt_tags": "Contact,Case,Adresse",
      "itt_userstories": "",
      "itt_enabled": true,
      "itt_definitionjson": {
        "preconditions": { "createContact": true, "createCase": true },
        "steps": [
          { "action": "UpdateRecord", "alias": "contact1", "fields": { "address1_city": "Berlin", "address1_postalcode": "10115" }, "waitForAsync": true }
        ],
        "assertions": [
          { "target": "Query", "entity": "incident", "filter": { "primarycontactid": "{contact1.id}" }, "field": "customeraddress_city", "operator": "Equals", "value": "Berlin" }
        ]
      }
    },
    {
      "itt_testcaseid": "d1d2d3d4-0005-4000-8000-100000000005",
      "itt_testid": "STD-TC05",
      "itt_title": "Task-Erinnerung: Workflow bei Fälligkeit",
      "itt_category": 100000005,
      "itt_tags": "Activity,Task,Workflow",
      "itt_userstories": "",
      "itt_enabled": true,
      "itt_definitionjson": {
        "steps": [
          { "action": "CreateRecord", "entity": "task", "alias": "task1", "fields": { "subject": "Rückruf {GENERATED:lastname}", "scheduledend": "{TIMESTAMP_PLUS_1H}", "prioritycode": 2, "regardingobjectid_contact": "{CONTACT_ID}" }, "waitForAsync": true }
        ],
        "assertions": [
          { "target": "Query", "entity": "activitypointer", "filter": { "regardingobjectid": "{task1.regardingobjectid}" }, "field": "statuscode", "operator": "NotEquals", "value": "5" }
        ]
      }
    },
    {
      "itt_testcaseid": "d1d2d3d4-0006-4000-8000-100000000006",
      "itt_testid": "STD-TC06",
      "itt_title": "Account-Deduplizierung: Warnung bei gleicher Email",
      "itt_category": 100000006,
      "itt_tags": "Account,Duplikat,DQM",
      "itt_userstories": "",
      "itt_enabled": true,
      "itt_definitionjson": {
        "preconditions": { "createAccount": true },
        "steps": [
          { "action": "CreateRecord", "entity": "account", "alias": "acc_dup", "fields": { "name": "{account1.name}", "emailaddress1": "{account1.emailaddress1}" } }
        ],
        "assertions": [
          { "target": "Query", "entity": "duplicaterecord", "filter": { "baserecordid": "{acc_dup.id}" }, "field": "duplicaterecordid", "operator": "IsNotNull" }
        ]
      }
    },
    {
      "itt_testcaseid": "d1d2d3d4-0007-4000-8000-100000000007",
      "itt_testid": "STD-TC07",
      "itt_title": "Opportunity-Pipeline: Phase-Wechsel Validierung",
      "itt_category": 100000005,
      "itt_tags": "Opportunity,BPF,Pipeline",
      "itt_userstories": "PROJ-2001",
      "itt_enabled": true,
      "itt_definitionjson": {
        "preconditions": { "createOpportunity": true },
        "steps": [
          { "action": "UpdateRecord", "alias": "opp1", "fields": { "stepname": "Propose", "salesstage": 2 }, "waitForAsync": true }
        ],
        "assertions": [
          { "target": "Record:opp1", "field": "salesstage", "operator": "Equals", "value": "2" },
          { "target": "Record:opp1", "field": "stepname", "operator": "Equals", "value": "Propose" }
        ]
      }
    },
    {
      "itt_testcaseid": "d1d2d3d4-0008-4000-8000-100000000008",
      "itt_testid": "STD-TC08",
      "itt_title": "Case-SLA: Timer startet bei Erstellung",
      "itt_category": 100000005,
      "itt_tags": "Case,SLA,Timer,Service",
      "itt_userstories": "PROJ-2002",
      "itt_enabled": true,
      "itt_definitionjson": {
        "steps": [
          { "action": "CreateRecord", "entity": "incident", "alias": "sla_case", "fields": { "title": "SLA-Test {GENERATED:text}", "prioritycode": 2, "customerid_account": "{ACCOUNT_ID}" }, "waitForAsync": true, "maxDurationMs": 10000 }
        ],
        "assertions": [
          { "target": "Record:sla_case", "field": "slainvokedid", "operator": "IsNotNull" }
        ]
      }
    }
  ],
