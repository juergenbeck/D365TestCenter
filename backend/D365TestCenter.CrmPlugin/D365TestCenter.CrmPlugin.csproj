<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net462</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>D365TestCenter.CrmPlugin</RootNamespace>
    <AssemblyName>D365TestCenter.CrmPlugin</AssemblyName>
    <Version>5.3.2</Version>
    <Authors>Integration Test Center Team</Authors>
    <Description>D365 Test Center - Plugin Package (Custom API + CRUD-Trigger)</Description>

    <!-- PluginPackage (NuGet): Dataverse managed Versionierung und Cache-Invalidierung -->
    <GeneratePackageOnBuild Condition="'$(Configuration)' == 'Release'">true</GeneratePackageOnBuild>
    <PackageId>jbe_D365TestCenter</PackageId>
    <PackageOutputPath>$(MSBuildThisFileDirectory)..\bin\Release\outputPackages</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CrmSdk.CoreAssemblies" Version="9.0.*">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\D365TestCenter.Core\D365TestCenter.Core.csproj" />
  </ItemGroup>

  <!-- ProjectReference-Assemblies + Bogus ins Paket einschliessen (CrmSdk bleibt aussen) -->
  <PropertyGroup>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);CopyProjectReferencesToPackage</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>

  <!--
    Kopiert das frisch gebaute NuGet-Paket automatisch nach solution/src/pluginpackages/,
    damit `pac solution pack` immer den aktuellen Plugin-Code einschliesst.
    Hintergrund: FB-26 (stale nupkg in solution/src nach Backend-Rebuild).
  -->
  <Target Name="CopyNupkgToSolutionSrc" AfterTargets="Pack" Condition="'$(Configuration)' == 'Release'">
    <Copy SourceFiles="$(PackageOutputPath)\$(PackageId).$(Version).nupkg"
          DestinationFiles="$(MSBuildThisFileDirectory)..\..\solution\src\pluginpackages\jbe_D365TestCenter\package\jbe_D365TestCenter.nupkg"
          SkipUnchangedFiles="false" />
    <Message Text="Copied $(PackageId).$(Version).nupkg to solution/src/pluginpackages/jbe_D365TestCenter/package/" Importance="high" />
  </Target>

  <!--
    Alle ReferenceCopyLocalPaths ins Paket einschliessen, aber Microsoft.*, System.* und
    CrmSdk DLLs ausschliessen (sind in der Sandbox verfuegbar).
  -->
  <Target Name="CopyProjectReferencesToPackage" DependsOnTargets="ResolveReferences">
    <ItemGroup>
      <BuildOutputInPackage Include="@(ReferenceCopyLocalPaths)"
        Condition="
          !$([System.String]::new('%(ReferenceCopyLocalPaths.Filename)').StartsWith('Microsoft.Crm'))
          AND !$([System.String]::new('%(ReferenceCopyLocalPaths.Filename)').StartsWith('Microsoft.Xrm'))
          AND !$([System.String]::new('%(ReferenceCopyLocalPaths.Filename)').StartsWith('Microsoft.IdentityModel'))
          AND !$([System.String]::new('%(ReferenceCopyLocalPaths.Filename)').StartsWith('Microsoft.Rest'))
          AND !$([System.String]::new('%(ReferenceCopyLocalPaths.Filename)').StartsWith('Microsoft.Win32'))
          AND !$([System.String]::new('%(ReferenceCopyLocalPaths.Filename)').StartsWith('Microsoft.Bcl'))
          AND !$([System.String]::new('%(ReferenceCopyLocalPaths.Filename)').StartsWith('System.'))
          AND '%(ReferenceCopyLocalPaths.Filename)' != 'netstandard'"
        TargetPath="%(ReferenceCopyLocalPaths.DestinationSubPath)" />
    </ItemGroup>
  </Target>

</Project>
