{
  "suiteId": "Recompute",
  "suiteName": "Batch Recompute Tests",
  "testCases": [
    {
      "id": "RTC01",
      "title": "Batch-Request setzt Status auf Requested",
      "category": "Batch-Recompute",
      "tags": ["recompute", "batch", "status", "happy-path"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "accountData": { "name": "{PREFIX}_RTC01_Account" },
        "contactData": [
          { "firstname": "{PREFIX}_RTC01_First_A", "lastname": "{PREFIX}_RTC01_Last_A", "ref": "CONTACT_A" },
          { "firstname": "{PREFIX}_RTC01_First_B", "lastname": "{PREFIX}_RTC01_Last_B", "ref": "CONTACT_B" }
        ],
        "contactSourceData": [
          { "contactRef": "CONTACT_A", "externalId": "{CONTACT_A_PLATFORMID}", "sourceSystemCode": 5 },
          { "contactRef": "CONTACT_B", "externalId": "{CONTACT_B_PLATFORMID}", "sourceSystemCode": 5 }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "RequestFieldGovernanceBatch API aufrufen mit 2 Contact-IDs",
          "action": "CallCustomApi",
          "data": {
            "apiName": "markant_RequestFieldGovernanceBatch",
            "parameters": {
              "ContactIds": "[\"{CONTACT_A_ID}\", \"{CONTACT_B_ID}\"]",
              "ResetFailed": false
            }
          },
          "waitForProcessing": false,
          "timeoutSeconds": 30
        }
      ],
      "assertions": [
        { "target": "Contact", "field": "markant_cdh_fg_requestcode", "operator": "Equals", "value": "595300001", "scope": "CONTACT_A", "description": "Contact A: RequestCode = Requested" },
        { "target": "Contact", "field": "markant_cdh_fg_requestcode", "operator": "Equals", "value": "595300001", "scope": "CONTACT_B", "description": "Contact B: RequestCode = Requested" },
        { "target": "ApiResponse", "field": "RequestedCount", "operator": "Equals", "value": "2", "description": "API meldet 2 Requested" },
        { "target": "ApiResponse", "field": "SkippedCount", "operator": "Equals", "value": "0", "description": "API meldet 0 Skipped" }
      ]
    },
    {
      "id": "RTC02",
      "title": "RequestPlugin verarbeitet Requested → Processing → Done",
      "category": "Batch-Recompute",
      "tags": ["recompute", "batch", "status-machine", "e2e"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "accountData": { "name": "{PREFIX}_RTC02_Account" },
        "contactData": { "firstname": "{PREFIX}_RTC02_First", "lastname": "{PREFIX}_RTC02_Last" },
        "contactSourceData": [
          { "externalId": "{CONTACT_PLATFORMID}", "sourceSystemCode": 5, "firstname": "{PREFIX}_RTC02_First", "lastname": "{PREFIX}_RTC02_Last" }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Batch-Request absetzen → Status wird auf Requested gesetzt",
          "action": "CallCustomApi",
          "data": {
            "apiName": "markant_RequestFieldGovernanceBatch",
            "parameters": {
              "ContactIds": "[\"{CONTACT_ID}\"]",
              "ResetFailed": false
            }
          },
          "waitForProcessing": false,
          "timeoutSeconds": 30
        },
        {
          "stepNumber": 2,
          "description": "Warten bis Field Governance den Contact verarbeitet hat",
          "action": "WaitForFieldGovernance",
          "data": {
            "contactRef": "default",
            "expectedRequestCode": "595300004"
          },
          "waitForProcessing": true,
          "timeoutSeconds": 180
        }
      ],
      "assertions": [
        { "target": "Contact", "field": "markant_cdh_fg_requestcode", "operator": "Equals", "value": "595300004", "description": "RequestCode = Done (Verarbeitung abgeschlossen)" },
        { "target": "CdhLogging", "operator": "Exists", "description": "CDH-Log für Recompute vorhanden" },
        { "target": "Contact", "field": "firstname", "operator": "Equals", "value": "{PREFIX}_RTC02_First", "description": "Kontakt-Daten wurden aus CS reaggregiert" }
      ]
    },
    {
      "id": "RTC03",
      "title": "Mehr als 200 IDs → Exception",
      "category": "Batch-Recompute",
      "tags": ["recompute", "batch", "limit", "error"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {},
      "steps": [
        {
          "stepNumber": 1,
          "description": "Batch-Request mit 201 GUIDs aufrufen → Limit überschritten",
          "action": "CallCustomApi",
          "data": {
            "apiName": "markant_RequestFieldGovernanceBatch",
            "parameters": {
              "ContactIds": "{GENERATE_GUID_ARRAY:201}",
              "ResetFailed": false
            },
            "expectException": true
          },
          "waitForProcessing": false,
          "timeoutSeconds": 30
        }
      ],
      "assertions": [
        { "target": "ApiResponse", "field": "exception", "operator": "IsNotNull", "description": "Exception wurde ausgelöst" },
        { "target": "ApiResponse", "field": "exceptionMessage", "operator": "Contains", "value": "Maximal", "description": "Fehlermeldung enthält 'Maximal'" },
        { "target": "ApiResponse", "field": "exceptionMessage", "operator": "Contains", "value": "201", "description": "Fehlermeldung enthält die übergebene Anzahl" }
      ]
    },
    {
      "id": "RTC04",
      "title": "ResetFailed setzt Failed → Requested",
      "category": "Batch-Recompute",
      "tags": ["recompute", "batch", "reset-failed"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "accountData": { "name": "{PREFIX}_RTC04_Account" },
        "contactData": { "firstname": "{PREFIX}_RTC04_First", "lastname": "{PREFIX}_RTC04_Last" },
        "contactSourceData": [
          { "externalId": "{CONTACT_PLATFORMID}", "sourceSystemCode": 5 }
        ],
        "contactOverrides": {
          "markant_cdh_fg_requestcode": 595300005
        }
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Batch-Request mit ResetFailed=true aufrufen",
          "action": "CallCustomApi",
          "data": {
            "apiName": "markant_RequestFieldGovernanceBatch",
            "parameters": {
              "ContactIds": "[\"{CONTACT_ID}\"]",
              "ResetFailed": true
            }
          },
          "waitForProcessing": false,
          "timeoutSeconds": 30
        }
      ],
      "assertions": [
        { "target": "Contact", "field": "markant_cdh_fg_requestcode", "operator": "Equals", "value": "595300001", "description": "RequestCode wurde von Failed auf Requested zurückgesetzt" },
        { "target": "ApiResponse", "field": "RequestedCount", "operator": "Equals", "value": "1", "description": "API meldet 1 Requested" }
      ]
    },
    {
      "id": "RTC05",
      "title": "Leere ID-Liste → kein Fehler",
      "category": "Batch-Recompute",
      "tags": ["recompute", "batch", "edge-case", "empty"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": false,
      "preconditions": {},
      "steps": [
        {
          "stepNumber": 1,
          "description": "Batch-Request mit leerer ID-Liste aufrufen",
          "action": "CallCustomApi",
          "data": {
            "apiName": "markant_RequestFieldGovernanceBatch",
            "parameters": {
              "ContactIds": "[]",
              "ResetFailed": false
            },
            "expectException": true
          },
          "waitForProcessing": false,
          "timeoutSeconds": 30
        }
      ],
      "assertions": [
        { "target": "ApiResponse", "field": "exception", "operator": "IsNotNull", "description": "API wirft Exception bei leerer Liste" },
        { "target": "ApiResponse", "field": "exceptionMessage", "operator": "Contains", "value": "leer", "description": "Fehlermeldung enthält 'leer'" }
      ]
    }
  ]
}
