      "assertions": [
        {
          "description": "Contact.firstname should be PISA_NEW (latest timestamp wins)",
          "target": "Contact",
          "field": "firstname",
          "operator": "Equals",
          "value": "PISA_NEW"
        }
      ]
    },
    {
      "id": "TC06",
      "title": "Update Multi Source – Last Update Wins – Update Multiple Snapshots",
      "description": "Pisa & Plattform senden Updates; der letzte (neuester Timestamp) gewinnt.",
      "category": "Update Source Record",
      "tags": ["LUW", "MultiSource", "MultiUpdate"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "existingContactSources": [
          {
            "alias": "pisa1",
            "sourceSystem": 4,
            "fields": {
              "markant_firstname": "TC06_ORIG",
              "markant_lastname": "TC06_Kontakt_{TIMESTAMP}"
            },
            "linkToContact": true,
            "waitForGovernance": true
          },
          {
            "alias": "platform1",
            "sourceSystem": 5,
            "fields": {
              "markant_firstname": "TC06_ORIG",
              "markant_lastname": "TC06_Kontakt_{TIMESTAMP}"
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Update Pisa Source: firstname = FN_PISA",
          "action": "UpdateContactSource",
          "targetAlias": "pisa1",
          "fields": {
            "markant_firstname": "FN_PISA"
          },
          "waitForGovernance": true
        },
        {
          "stepNumber": 2,
          "description": "Wait 2 seconds to ensure timestamp difference",
          "action": "Delay",
          "delayMs": 2000
        },
        {
          "stepNumber": 3,
          "description": "Update Platform Source: firstname = FN_PLAT (later timestamp)",
          "action": "UpdateContactSource",
          "targetAlias": "platform1",
          "fields": {
            "markant_firstname": "FN_PLAT"
          },
          "waitForGovernance": true
        }
      ],
      "assertions": [
        {
          "description": "Contact.firstname should be FN_PLAT (latest timestamp wins)",
          "target": "Contact",
          "field": "firstname",
          "operator": "Equals",
          "value": "FN_PLAT"
        }
      ]
    },
