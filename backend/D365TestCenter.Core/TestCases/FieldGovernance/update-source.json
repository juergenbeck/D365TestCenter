{
  "suiteId": "FG-UpdateSource",
  "suiteName": "FGTC – Existing Contact – Update Source Record",
  "suiteDescription": "Tests für das Aktualisieren bestehender CDH Contact Source Records und Überprüfung der Field Governance Ergebnisse. Basiert auf DYN-T683, DYN-T684, DYN-T685.",
  "testCases": [
    {
      "id": "TC01",
      "title": "Update Single Source – Last Update Wins – Update Single Field",
      "description": "Ein existierender CDH Contact Source Record (Quelle: Pisa). Feld firstname wird durch Last Update Wins gesteuert. Update auf markant_firstname.",
      "category": "Update Source Record",
      "tags": ["LUW", "SingleSource", "SingleField"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "existingContactSources": [
          {
            "alias": "pisa1",
            "sourceSystem": 4,
            "fields": {
              "markant_firstname": "TC01_ORIG_FN",
              "markant_lastname": "TC01_Kontakt_{TIMESTAMP}"
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Update Pisa Source: markant_firstname = NEW_FN",
          "action": "UpdateContactSource",
          "targetAlias": "pisa1",
          "fields": {
            "markant_firstname": "NEW_FN"
          },
          "waitForGovernance": true
        }
      ],
      "assertions": [
        {
          "description": "Contact.firstname should be NEW_FN",
          "target": "Contact",
          "field": "firstname",
          "operator": "Equals",
          "value": "NEW_FN"
        },
        {
          "description": "CDH Logging entry should exist",
          "target": "CdhLogging",
          "field": "",
          "operator": "Exists"
        },
        {
          "description": "CDH Log should show contact was updated",
          "target": "CdhLogging",
          "field": "",
          "operator": "ContactUpdated",
          "value": "true"
        }
      ]
    },
    {
      "id": "TC02",
      "title": "Update Single Source – Last Update Wins – Update All Fields",
      "description": "Mehrere Data Fields werden gleichzeitig im CDH Contact Source aktualisiert.",
      "category": "Update Source Record",
      "tags": ["LUW", "SingleSource", "MultiField"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "existingContactSources": [
          {
            "alias": "pisa1",
            "sourceSystem": 4,
            "fields": {
              "markant_firstname": "TC02_OLD_FN",
              "markant_lastname": "TC02_OLD_LN_{TIMESTAMP}",
              "markant_jobtitle": "TC02_OLD_JT"
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Update all fields on Pisa Source",
          "action": "UpdateContactSource",
          "targetAlias": "pisa1",
          "fields": {
            "markant_firstname": "FN_NEW",
            "markant_lastname": "LN_NEW",
            "markant_jobtitle": "JT_NEW"
          },
          "waitForGovernance": true
        }
      ],
      "assertions": [
        {
          "description": "Contact.firstname should be FN_NEW",
          "target": "Contact",
          "field": "firstname",
          "operator": "Equals",
          "value": "FN_NEW"
        },
        {
          "description": "Contact.lastname should be LN_NEW",
          "target": "Contact",
          "field": "lastname",
          "operator": "Equals",
          "value": "LN_NEW"
        },
        {
          "description": "Contact.jobtitle should be JT_NEW",
          "target": "Contact",
          "field": "jobtitle",
          "operator": "Equals",
          "value": "JT_NEW"
        }
      ]
    },
    {
      "id": "TC03",
      "title": "Update Single Source – Last Update Wins – No Effective Change",
      "description": "Source wird mit identischem Wert aktualisiert. Contact darf sich nicht ändern (No-Op).",
      "category": "Update Source Record",
      "tags": ["LUW", "NoOp"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "contactData": {
          "firstname": "TC_FN"
        },
        "existingContactSources": [
          {
            "alias": "pisa1",
            "sourceSystem": 4,
            "fields": {
              "markant_firstname": "TC_FN",
              "markant_lastname": "TC03_Kontakt_{TIMESTAMP}"
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ],
        "contactInitialState": {
          "firstname": "TC_FN"
        }
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Update Pisa Source with identical value",
          "action": "UpdateContactSource",
          "targetAlias": "pisa1",
          "fields": {
            "markant_firstname": "TC_FN"
          },
          "waitForGovernance": true
        }
      ],
      "assertions": [
        {
          "description": "Contact.firstname should remain TC_FN",
          "target": "Contact",
          "field": "firstname",
          "operator": "Equals",
          "value": "TC_FN"
        }
      ]
    },
    {
