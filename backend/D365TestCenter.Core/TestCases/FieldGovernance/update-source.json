              "markant_firstname": "TC05_PISA_ORIG",
              "markant_lastname": "TC05_Kontakt_{TIMESTAMP}"
            },
            "linkToContact": true,
            "waitForGovernance": true
          },
          {
            "alias": "platform1",
            "sourceSystem": 5,
            "fields": {
              "markant_firstname": "TC05_PLAT_ORIG",
              "markant_lastname": "TC05_Kontakt_{TIMESTAMP}"
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Update Pisa Source: firstname = PISA_NEW",
