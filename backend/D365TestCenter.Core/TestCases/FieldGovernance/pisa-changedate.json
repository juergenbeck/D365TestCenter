{
  "suiteId": "FG-PisaChangedate",
  "suiteName": "FGTC – PISA IF Changedate & IF Import Source",
  "suiteDescription": "Tests für PISA-spezifisches Verhalten: pisa_if_changedate Marker und IF Import Source Feld. Basiert auf DYN-T691.",
  "testCases": [
    {
      "id": "TCPISA01",
      "title": "Update PISA Source – Wert auf Kontakt, Import Source = PISA, kein ChangeDate",
      "description": "Kontakt existiert. Update eines PISA SourceRecords: markant_firstname = NEW_FN wird Gewinner. pisa_if_changedate bleibt unverändert (da Feature ausschließlich bei Pisa-Winner über Governance).",
      "category": "PISA IF",
      "tags": ["PISA", "ImportSource", "ChangeDate"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "existingContactSources": [
          {
            "alias": "pisa1",
            "sourceSystem": 4,
            "fields": {
              "markant_firstname": "TCPISA01_ORIG",
              "markant_lastname": "TCPISA01_Kontakt_{TIMESTAMP}"
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Update PISA Source: markant_firstname = NEW_FN",
          "action": "UpdateContactSource",
          "targetAlias": "pisa1",
          "fields": {
            "markant_firstname": "NEW_FN"
          },
          "waitForGovernance": true
        }
      ],
      "assertions": [
        {
          "description": "Contact.firstname should be NEW_FN",
          "target": "Contact",
          "field": "firstname",
          "operator": "Equals",
          "value": "NEW_FN"
        },
        {
          "description": "pisa_if_changedate should be set recently (Pisa Winner → FG sets marker)",
          "target": "Contact",
          "field": "markant_pisa_if_changedate",
          "operator": "DateSetRecently",
          "withinSeconds": 300
        },
        {
          "description": "CDH Logging entry should exist with FG Decision",
          "target": "CdhLogging",
          "operator": "Exists"
        },
        {
          "description": "CDH Log should confirm contact was updated",
          "target": "CdhLogging",
          "operator": "ContactUpdated",
          "value": "true"
        }
      ]
    },
    {
      "id": "TCPISA02",
      "title": "Create PISA Source – Wert auf Kontakt, Import Source = PISA, kein ChangeDate",
      "description": "Kontakt existiert. Create PISA SourceRecord: firstname=C_FN → Kontakt übernimmt.",
      "category": "PISA IF",
      "tags": ["PISA", "ImportSource", "Create"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "contactData": {
          "firstname": "TCPISA02_ORIG",
          "lastname": "TCPISA02_Kontakt_{TIMESTAMP}"
        }
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Create PISA Source: firstname = C_FN",
          "action": "CreateContactSource",
          "targetAlias": "pisa1",
          "sourceSystem": 4,
          "fields": {
            "markant_firstname": "C_FN",
            "markant_lastname": "TCPISA02_Kontakt_{TIMESTAMP}"
          },
          "linkToContact": true,
          "waitForGovernance": true
        }
      ],
      "assertions": [
        {
          "description": "Contact.firstname should be C_FN",
          "target": "Contact",
          "field": "firstname",
          "operator": "Equals",
          "value": "C_FN"
        },
        {
          "description": "pisa_if_changedate should be set recently (Pisa Winner)",
          "target": "Contact",
          "field": "markant_pisa_if_changedate",
          "operator": "DateSetRecently",
          "withinSeconds": 300
        }
      ]
    },
