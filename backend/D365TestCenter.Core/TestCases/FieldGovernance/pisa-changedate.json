    {
      "id": "TCPISA04",
      "title": "Create PLATTFORM Source – Wert übernimmt, Import Source = PLATTFORM, ChangeDate gesetzt",
      "description": "Kontakt existiert, IF Import Source = MNET. Create PLATTFORM Source → firstname übernommen.",
      "category": "PISA IF",
      "tags": ["PISA", "Platform", "ChangeDate", "Create"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
