    {
      "id": "TCPISA05",
      "title": "Manuelle Änderung eines PISA-relevanten Kontaktfelds – ChangeDate setzen",
      "description": "Kontakt existiert. Benutzer ändert firstname direkt am Kontakt → pisa_if_changedate sollte nach Governance-Lauf gesetzt werden.",
      "category": "PISA IF",
      "tags": ["PISA", "ManualChange", "ChangeDate"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "existingContactSources": [
          {
            "alias": "pisa1",
            "sourceSystem": 4,
            "fields": {
              "markant_firstname": "TCPISA05_ORIG",
              "markant_lastname": "TCPISA05_Kontakt_{TIMESTAMP}"
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Direkte Änderung am Kontakt: firstname = MANUAL_CHANGE",
          "action": "UpdateContact",
          "fields": {
            "firstname": "MANUAL_CHANGE"
          },
          "waitForGovernance": false
        },
        {
          "stepNumber": 2,
          "description": "Warte auf SnapshotWriter und FG",
          "action": "Wait",
          "waitSeconds": 15
        }
      ],
      "assertions": [
        {
          "description": "Contact.firstname should be MANUAL_CHANGE (or governance may have reverted)",
          "target": "Contact",
          "field": "firstname",
          "operator": "IsNotNull"
        }
      ],
      "asyncWaitOverrideSeconds": 30
    }
  ]
}
