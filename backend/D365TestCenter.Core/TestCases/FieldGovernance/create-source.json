      "description": "Dynamics leer. Pisa erstellt → Pisa gewinnt, da Dynamics keinen Wert hat.",
      "category": "Create Source Record",
      "tags": ["PriorityOrder", "MultiSource", "Create", "FallbackPriority"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "existingContactSources": [
          {
            "alias": "dynamics1",
            "sourceSystem": 1,
            "fields": {
              "markant_firstname": "TCC10_FN",
              "markant_lastname": "TCC10_Kontakt_{TIMESTAMP}"
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
