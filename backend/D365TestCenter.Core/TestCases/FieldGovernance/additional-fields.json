{
  "suiteId": "FG-AdditionalFields",
  "suiteName": "FGTC – Additional Fields Coverage",
  "suiteDescription": "Tests für die 7 zusätzlichen Governance-Felder: markant_academictitle, gendercode, middlename, mobilephone, telephone2 (alle LUW), telephone1 (Priority, nur Dynamics), parentcustomerid (Priority). Einzeltests plus komplexe Multi-Feld-Szenarien.",
  "testCases": [
    {
      "id": "TCUF01",
      "title": "markant_academictitle – LUW: Pisa überschreibt Dynamics",
      "description": "Dynamics liefert markant_academictitle = 'Dr.'. Pisa (neuer) liefert 'Prof. Dr.'. LUW → Pisa gewinnt.",
      "category": "Additional Fields",
      "tags": ["LUW", "academictitle", "MultiSource"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "existingContactSources": [
          {
            "alias": "dynamics1",
            "sourceSystem": 1,
            "fields": {
              "markant_firstname": "DYN_FN",
              "markant_lastname": "TCUF01_Kontakt_{TIMESTAMP}",
              "markant_academictitle": "Dr."
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Create Pisa Source: markant_academictitle = Prof. Dr.",
          "action": "CreateContactSource",
          "targetAlias": "pisa1",
          "sourceSystem": 4,
          "fields": {
            "markant_lastname": "TCUF01_Kontakt_{TIMESTAMP}",
            "markant_academictitle": "Prof. Dr."
          },
          "linkToContact": true,
          "waitForGovernance": true
        }
      ],
      "assertions": [
        {
          "description": "Contact.markant_academictitle = 'Prof. Dr.' (LUW: Pisa neuer)",
          "target": "Contact",
          "field": "markant_academictitle",
          "operator": "Equals",
          "value": "Prof. Dr."
        }
      ]
    },
