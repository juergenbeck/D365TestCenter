{
  "suiteId": "FG-MultiSourceMultiField",
  "suiteName": "FGTC – Multi-Source Multi-Field Governance",
  "suiteDescription": "Erweiterte Tests für LUW und Priority Order Felder über Dynamics, Pisa und Plattform. Validiert gemischte Strategieentscheidungen, partielle Datenlieferung, Prioritätskaskadierung, Leerwert-Schutz und LUW Ping-Pong.",
  "testCases": [
    {
      "id": "TCMF01",
      "title": "Dynamics blockiert Priority-Feld – Pisa gewinnt LUW-Felder",
      "description": "Dynamics liefert emailaddress1 + LUW-Felder. Pisa (neuer) liefert dieselben Felder. LUW-Felder gehen an Pisa, emailaddress1 bleibt bei Dynamics (Rank 1).",
      "category": "Multi-Source Multi-Field",
      "tags": ["PriorityOrder", "LUW", "MultiSource", "MultiField", "DynamicsBlock"],
      "enabled": true,
      "dataMode": "template",
      "cleanupAfterTest": true,
      "preconditions": {
        "createContact": true,
        "createAccount": true,
        "existingContactSources": [
          {
            "alias": "dynamics1",
            "sourceSystem": 1,
            "fields": {
              "markant_firstname": "DYN_FN",
              "markant_lastname": "TCMF01_Kontakt_{TIMESTAMP}",
              "markant_emailaddress1": "dyn@mail.com"
            },
            "linkToContact": true,
            "waitForGovernance": true
          }
        ]
      },
      "steps": [
        {
          "stepNumber": 1,
          "description": "Create Pisa Source with identical fields but different values",
          "action": "CreateContactSource",
          "targetAlias": "pisa1",
          "sourceSystem": 4,
          "fields": {
            "markant_firstname": "PISA_FN",
            "markant_lastname": "TCMF01_Kontakt_{TIMESTAMP}",
            "markant_emailaddress1": "pisa@mail.com"
          },
          "linkToContact": true,
          "waitForGovernance": true
        }
      ],
      "assertions": [
        {
          "description": "Contact.firstname = PISA_FN (LUW: Pisa neuer als Dynamics)",
          "target": "Contact",
          "field": "firstname",
          "operator": "Equals",
          "value": "PISA_FN"
        },
        {
          "description": "Contact.emailaddress1 = dyn@mail.com (Priority: Dynamics Rank 1 blockiert)",
          "target": "Contact",
          "field": "emailaddress1",
          "operator": "Equals",
          "value": "dyn@mail.com"
        },
        {
          "description": "CDH Log should exist",
          "target": "CdhLogging",
          "operator": "Exists"
        }
      ]
    },
    {
